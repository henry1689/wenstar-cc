# ──────────────────────────────────────────────
# 仿生智脑 (Bionic Cognitive Engine) — 环境变量
# ──────────────────────────────────────────────

# === FastAPI ===
API_HOST=0.0.0.0
API_PORT=7200
API_DEBUG=false
API_SECRET_KEY=change-me-to-a-random-64-char-string

# === PostgreSQL ===
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=bionic
POSTGRES_USER=bionic
POSTGRES_PASSWORD=bionic_secret_2026

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# === Qdrant (Vector DB) ===
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=bionic_vectors

# === MinIO (Object Storage) ===
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=bionic_admin
MINIO_SECRET_KEY=bionic_secret_2026
MINIO_BUCKET=bionic-alluvial

# === LLM API ===
LLM_API_URL=http://host.docker.internal:3000/api/chat
LLM_API_KEY=
LLM_TIMEOUT=60
LLM_MAX_RETRIES=3

# === Decay (half-life) ===
DECAY_DEMOTE_DAYS=30
DECAY_ARCHIVE_DAYS=90

# === Celery ===
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
